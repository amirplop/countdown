<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Universal File Viewer</title>

<style>
body{
    margin:0;
    font-family:Arial, sans-serif;
    background:#111827;
    color:white;
}

.container{
    max-width:1000px;
    margin:auto;
    padding:30px;
}

h1{
    text-align:center;
}

.upload-box{
    border:3px dashed #4f46e5;
    border-radius:15px;
    padding:50px;
    text-align:center;
    margin-top:20px;
    cursor:pointer;
}

.upload-box:hover{
    background:#1f2937;
}

input{
    display:none;
}

.preview{
    margin-top:25px;
    background:#1f2937;
    border-radius:10px;
    padding:20px;
}

.file-info{
    margin-bottom:15px;
}

button{
    background:#4f46e5;
    color:white;
    border:none;
    padding:12px 20px;
    border-radius:8px;
    cursor:pointer;
}

button:hover{
    background:#6366f1;
}

pre{
    max-height:400px;
    overflow:auto;
    background:#111827;
    padding:10px;
    border-radius:8px;
}
</style>
</head>

<body>

<div class="container">

<h1>Universal File Importer</h1>

<label class="upload-box">
    <h2>Drop Files Here</h2>
    <p>Supports Any File Type</p>
    <p>.kicad_sch, .kicad_pcb, PDFs, Images, ZIPs, etc.</p>
    <input type="file" id="fileInput">
</label>

<div id="preview" class="preview" style="display:none">
    <div class="file-info">
        <h2 id="fileName"></h2>
        <p id="fileSize"></p>
        <p id="fileType"></p>
    </div>

    <button id="downloadBtn">
        Download File
    </button>

    <h3 style="margin-top:20px;">Preview</h3>
    <pre id="contentPreview"></pre>
</div>

</div>

<script>

let uploadedFile = null;

const fileInput = document.getElementById("fileInput");

fileInput.addEventListener("change", e => {

    uploadedFile = e.target.files[0];

    if(!uploadedFile) return;

    document.getElementById("preview").style.display = "block";

    document.getElementById("fileName").textContent =
        "Name: " + uploadedFile.name;

    document.getElementById("fileSize").textContent =
        "Size: " + (uploadedFile.size / 1024).toFixed(2) + " KB";

    document.getElementById("fileType").textContent =
        "Type: " + (uploadedFile.type || "Unknown");

    const reader = new FileReader();

    reader.onload = function(event){

        let text = event.target.result;

        document.getElementById("contentPreview").textContent =
            text.substring(0, 5000);

    };

    reader.readAsText(uploadedFile);

});

document.getElementById("downloadBtn")
.addEventListener("click", () => {

    if(!uploadedFile) return;

    const url = URL.createObjectURL(uploadedFile);

    const a = document.createElement("a");

    a.href = url;
    a.download = uploadedFile.name;

    document.body.appendChild(a);

    a.click();

    document.body.removeChild(a);

    URL.revokeObjectURL(url);

});

</script>

</body>
</html>
